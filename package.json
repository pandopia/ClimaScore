{
  "name": "meteoweight",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "scripts": {
    "ng": "ng",
    "dev": "env CI=1 NG_CLI_ANALYTICS=false ng serve",
    "build": "env NG_BUILD_MAX_WORKERS=1 CI=1 ng build",
    "watch": "env NG_BUILD_MAX_WORKERS=1 ng build --watch --configuration development",
    "test": "npm run test:etl && npm run test:front -- --watch=false",
    "test:front": "ng test",
    "test:etl": "node --test scripts/etl/*.test.js",
    "etl": "node scripts/etl/build-dashboard.js"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
